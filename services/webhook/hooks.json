[
  {
    "id": "rebuild-linus",
    "execute-command": "/bin/sh",
    "command-working-directory": "/opt/Jannik-Cloud",
    "pass-arguments-to-command": [
      {
        "source": "string",
        "name": "/etc/webhook/scripts/rebuild-linus.sh"
      }
    ],
    "response-message": "Linus rebuild triggered.",
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "payload-hmac-sha256",
            "secret": "{{ getenv \"WEBHOOK_SECRET\" }}",
            "parameter": {
              "source": "header",
              "name": "X-Hub-Signature-256"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    },
    "include-command-output-in-response": false
  },
  {
    "id": "deploy-cloud",
    "execute-command": "/bin/sh",
    "command-working-directory": "/opt/Jannik-Cloud",
    "pass-arguments-to-command": [
      {
        "source": "string",
        "name": "/etc/webhook/scripts/deploy-cloud.sh"
      }
    ],
    "response-message": "Jannik-Cloud deploy triggered.",
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "payload-hmac-sha256",
            "secret": "{{ getenv \"WEBHOOK_SECRET\" }}",
            "parameter": {
              "source": "header",
              "name": "X-Hub-Signature-256"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    },
    "include-command-output-in-response": false
  },
  {
    "id": "rebuild-cbrn",
    "execute-command": "/bin/sh",
    "command-working-directory": "/opt/Jannik-Cloud",
    "pass-arguments-to-command": [
      {
        "source": "string",
        "name": "/etc/webhook/scripts/rebuild-cbrn.sh"
      }
    ],
    "response-message": "CBRN rebuild triggered.",
    "trigger-rule": {
      "and": [
        {
          "match": {
            "type": "payload-hmac-sha256",
            "secret": "{{ getenv \"WEBHOOK_SECRET\" }}",
            "parameter": {
              "source": "header",
              "name": "X-Hub-Signature-256"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "orfelorfel23/Content-Vault",
            "parameter": {
              "source": "payload",
              "name": "repository.full_name"
            }
          }
        },
        {
          "match": {
            "type": "value",
            "value": "refs/heads/main",
            "parameter": {
              "source": "payload",
              "name": "ref"
            }
          }
        }
      ]
    },
    "include-command-output-in-response": false
  }
]
